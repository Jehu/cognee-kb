---
const { title = 'KB' } = Astro.props;
const path = Astro.url.pathname;
const nav = [
  { href: '/', label: 'Ingest' },
  { href: '/chat', label: 'Chat' },
  { href: '/settings', label: 'Einstellungen' },
];
const isActive = (href) =>
  href === '/' ? path === '/' : path === href || path === href + '/';
---
<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#101418" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" href="/icons/icon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/icons/icon.svg" />
    <title>{title} · KB</title>
  </head>
  <body>
    <header>
      <nav>
        {nav.map((item) => (
          <a href={item.href} class:list={[{ active: isActive(item.href) }]}>{item.label}</a>
        ))}
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js').catch(() => {});
      }
    </script>
    <style is:global>
      :root {
        --bg: #101418;
        --surface: #1a2026;
        --border: #2c343c;
        --text: #e6e9ec;
        --muted: #8a949e;
        --accent: #4da3ff;
        --error: #ff6b6b;
        --ok: #5dd39e;
      }
      * { box-sizing: border-box; }
      html, body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        font-size: 16px;
      }
      header {
        position: sticky;
        top: 0;
        background: var(--surface);
        border-bottom: 1px solid var(--border);
        padding-top: env(safe-area-inset-top);
      }
      nav {
        display: flex;
        max-width: 640px;
        margin: 0 auto;
      }
      nav a {
        flex: 1;
        text-align: center;
        padding: 0.9rem 0.5rem;
        color: var(--muted);
        text-decoration: none;
        font-weight: 600;
      }
      nav a.active {
        color: var(--accent);
        border-bottom: 2px solid var(--accent);
      }
      main {
        max-width: 640px;
        margin: 0 auto;
        padding: 1rem;
        padding-bottom: calc(2rem + env(safe-area-inset-bottom));
      }
      h1 { font-size: 1.3rem; margin: 0.5rem 0 1rem; }
      label { display: block; margin: 0.8rem 0 0.3rem; color: var(--muted); font-size: 0.9rem; }
      input, textarea, select, button {
        width: 100%;
        padding: 0.7rem;
        border-radius: 8px;
        border: 1px solid var(--border);
        background: var(--surface);
        color: var(--text);
        font-size: 1rem;
        font-family: inherit;
      }
      textarea { min-height: 7rem; resize: vertical; }
      button {
        margin-top: 1rem;
        background: var(--accent);
        color: #0b1016;
        border: none;
        font-weight: 700;
        cursor: pointer;
      }
      button:disabled { opacity: 0.5; cursor: default; }
      .status { margin-top: 1rem; padding: 0.8rem; border-radius: 8px; background: var(--surface); border: 1px solid var(--border); white-space: pre-wrap; }
      .status.error { color: var(--error); border-color: var(--error); }
      .status.ok { color: var(--ok); border-color: var(--ok); }
      .hidden { display: none; }
    </style>
  </body>
</html>
