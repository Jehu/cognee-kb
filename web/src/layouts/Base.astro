---
const { title = 'KB' } = Astro.props;
const path = Astro.url.pathname;
const nav = [
  { href: '/', label: 'Ingest', icon: '+' },
  { href: '/chat/', label: 'Chat', icon: '?' },
  { href: '/settings/', label: 'Einstellungen', icon: '=' },
];
const isActive = (href) =>
  href === '/' ? path === '/' : path === href || path === href + '/';
---
<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#101418" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" href="/icons/icon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/icons/icon.svg" />
    <title>{title} · KB</title>
  </head>
  <body>
    <header>
      <nav>
        {nav.map((item) => (
          <a href={item.href} class:list={[{ active: isActive(item.href) }]}>
            <span class="nav-icon" aria-hidden="true">{item.icon}</span>
            <span class="nav-label">{item.label}</span>
          </a>
        ))}
      </nav>
    </header>
    <div id="token-hinweis" class="token-hinweis hidden">
      Kein Zugriffstoken gesetzt — <a href="/settings/">Token setzen</a>.
    </div>
    <main>
      <slot />
    </main>
    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js').catch(() => {});
      }
      // Dezenter Hinweis, wenn ohne Token geladen wird (außer auf /settings).
      (() => {
        const el = document.getElementById('token-hinweis');
        if (!el) return;
        const hasToken = !!localStorage.getItem('kb_token');
        const onSettings = location.pathname.replace(/\/$/, '') === '/settings';
        if (!hasToken && !onSettings) el.classList.remove('hidden');
      })();
    </script>
    <style is:global>
      :root {
        --bg: #101418;
        --surface: #1a2026;
        --border: #2c343c;
        --text: #e6e9ec;
        --muted: #8a949e;
        --accent: #4da3ff;
        --error: #ff6b6b;
        --ok: #5dd39e;
        --local: #5dd39e;
        --cloud: #ffcc66;
      }
      * { box-sizing: border-box; }
      html, body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        font-size: 16px;
      }
      header {
        position: sticky;
        top: 0;
        background: var(--surface);
        border-bottom: 1px solid var(--border);
        padding-top: env(safe-area-inset-top);
      }
      nav {
        display: flex;
        max-width: 640px;
        margin: 0 auto;
      }
      nav a {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.35rem;
        text-align: center;
        padding: 0.9rem 0.5rem;
        color: var(--muted);
        text-decoration: none;
        font-weight: 600;
      }
      .nav-icon { display: none; }
      nav a.active {
        color: var(--accent);
        border-bottom: 2px solid var(--accent);
      }
      main {
        max-width: 640px;
        margin: 0 auto;
        padding: 1rem;
        padding-bottom: calc(2rem + env(safe-area-inset-bottom));
      }
      h1 { font-size: 1.3rem; margin: 0.5rem 0 1rem; }
      .page-intro { margin: 0.2rem 0 1rem; }
      .page-intro h1 { margin-bottom: 0.25rem; }
      .page-intro p { margin: 0; color: var(--muted); line-height: 1.4; }
      label { display: block; margin: 0.8rem 0 0.3rem; color: var(--muted); font-size: 0.9rem; }
      input, textarea, select, button {
        width: 100%;
        padding: 0.7rem;
        border-radius: 8px;
        border: 1px solid var(--border);
        background: var(--surface);
        color: var(--text);
        font-size: 1rem;
        font-family: inherit;
      }
      input:focus-visible,
      textarea:focus-visible,
      select:focus-visible,
      button:focus-visible,
      a:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
      }
      textarea { min-height: 7rem; resize: vertical; }
      button {
        margin-top: 1rem;
        background: var(--accent);
        color: #0b1016;
        border: none;
        font-weight: 700;
        cursor: pointer;
      }
      button:disabled { opacity: 0.5; cursor: default; }
      button.secondary {
        margin-top: 0.5rem;
        background: transparent;
        color: var(--accent);
        border: 1px solid var(--border);
      }
      button.secondary:hover {
        border-color: var(--accent);
        background: color-mix(in srgb, var(--accent) 7%, transparent);
      }
      select:disabled,
      input:disabled,
      textarea:disabled {
        opacity: 0.65;
        cursor: not-allowed;
      }
      .control-row {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 0.5rem;
        align-items: end;
      }
      .control-row button {
        width: auto;
        min-width: 7rem;
        margin-top: 0;
        padding-inline: 0.9rem;
      }
      .status { margin-top: 1rem; padding: 0.8rem; border-radius: 8px; background: var(--surface); border: 1px solid var(--border); white-space: pre-wrap; }
      .status.error { color: var(--error); border-color: var(--error); }
      .status.ok { color: var(--ok); border-color: var(--ok); }
      .status a { color: var(--accent); font-weight: 700; }
      .wall-badge {
        display: inline-flex;
        align-items: center;
        border: 1px solid var(--border);
        border-radius: 999px;
        padding: 0.08rem 0.45rem;
        font-size: 0.72rem;
        font-weight: 700;
        line-height: 1.4;
      }
      .wall-badge.local { color: var(--local); border-color: color-mix(in srgb, var(--local) 55%, var(--border)); }
      .wall-badge.cloud { color: var(--cloud); border-color: color-mix(in srgb, var(--cloud) 55%, var(--border)); }
      .meta-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
        align-items: center;
        color: var(--muted);
        font-size: 0.82rem;
      }
      .hidden { display: none; }
      .token-hinweis {
        max-width: 640px;
        margin: 0 auto;
        padding: 0.6rem 1rem;
        font-size: 0.9rem;
        color: var(--muted);
        background: var(--surface);
        border-bottom: 1px solid var(--border);
        border-left: 3px solid var(--accent);
      }
      .token-hinweis a { color: var(--accent); font-weight: 600; }
      @media (max-width: 520px) {
        header {
          position: fixed;
          top: auto;
          right: 0;
          bottom: 0;
          left: 0;
          z-index: 10;
          border-top: 1px solid var(--border);
          border-bottom: 0;
          padding-top: 0;
          padding-bottom: env(safe-area-inset-bottom);
        }
        nav a {
          min-height: 3.6rem;
          flex-direction: column;
          gap: 0.12rem;
          padding: 0.45rem 0.35rem;
          font-size: 0.78rem;
        }
        .nav-icon {
          display: block;
          font-size: 1.05rem;
          line-height: 1;
        }
        nav a.active {
          border-bottom: 0;
          border-top: 2px solid var(--accent);
        }
        main {
          padding-bottom: calc(5rem + env(safe-area-inset-bottom));
        }
        .token-hinweis {
          margin-bottom: calc(3.6rem + env(safe-area-inset-bottom));
        }
        .control-row {
          grid-template-columns: 1fr;
        }
        .control-row button {
          width: 100%;
        }
      }
    </style>
  </body>
</html>
