---
import Base from '../layouts/Base.astro';
---
<Base title="Erfassen">
  <div class="page-intro">
    <p class="label" style="margin:0">Quelle erfassen</p>
    <h1>Was willst du festhalten?</h1>
    <p>Link, Notiz oder Text — die Verarbeitung läuft im Hintergrund.</p>
  </div>

  <form id="form">
    <label for="vault">Vault</label>
    <select id="vault" required></select>
    <div id="vault-hint" class="vault-hint hidden"></div>

    <label for="content">Quelle oder Notiz</label>
    <textarea id="content" placeholder="Link einfügen oder Notiz schreiben" required autofocus></textarea>

    <details style="margin-top:16px">
      <summary style="font-family:var(--font-mono);font-size:12px;letter-spacing:0.06em;text-transform:uppercase;color:var(--color-muted);cursor:pointer;padding:8px 0">Metadaten</summary>
      <label for="node_set" style="margin-top:12px">Node-Set</label>
      <input id="node_set" type="text" list="ns-sug" placeholder="z.B. projekte" autocapitalize="off" autocomplete="off" />
      <datalist id="ns-sug"></datalist>
    </details>

    <button type="submit" id="submit" class="btn-primary" disabled>Speichern</button>
  </form>

  <ol id="steps" class="job-steps hidden">
    <li data-step="accepted">Angenommen</li>
    <li data-step="running">Verarbeitung</li>
    <li data-step="done">Fertig</li>
  </ol>
  <div id="status" class="status hidden"></div>

  <script>
    import { getDefaultVault } from '../lib/api.js';
    import { initVaultSelect, getVaultMeta, loadNodeSets } from '../lib/bootstrap.js';

    const form = document.getElementById('form');
    const vaultSel = document.getElementById('vault');
    const vaultHint = document.getElementById('vault-hint');
    const nsSug = document.getElementById('ns-sug');
    const submit = document.getElementById('submit');
    const status = document.getElementById('status');
    const steps = document.getElementById('steps');
    let ready = false;
    let pollAbort = false;

    function setStatus(text, cls = '') {
      status.className = `status ${cls}`.trim();
      status.textContent = text;
      status.classList.remove('hidden');
    }

    function setStep(state) {
      steps.classList.remove('hidden');
      for (const li of steps.children) li.className = '';
      if (state === 'accepted') steps.querySelector('[data-step="accepted"]').className = 'active';
      if (state === 'running') {
        steps.querySelector('[data-step="accepted"]').className = 'done';
        steps.querySelector('[data-step="running"]').className = 'active';
      }
      if (state === 'done') steps.querySelectorAll('li').forEach(li => li.className = 'done');
    }

    function currentVault() { return (vaultSel.selectedOptions[0]?.parentNode?.label || '').toLowerCase(); }
    function showVaultHint() {
      vaultHint.classList.remove('hidden');
      const w = currentVault();
      vaultHint.className = `vault-hint ${w}`;
      vaultHint.innerHTML = `<span class="wall-dot ${w}"></span> ${
        w === 'local' ? 'Bleibt auf diesem Gerät · Ollama (lokal)'
        : 'Cloud-Verarbeitung · OpenRouter'}`;
    }

    initVaultSelect(vaultSel).then(state => {
      ready = state.ok;
      submit.disabled = !ready;
      if (ready) { showVaultHint(); loadNodeSets(vaultSel.value, nsSug); }
    });

    vaultSel.addEventListener('change', () => {
      showVaultHint();
      loadNodeSets(vaultSel.value, nsSug);
    });

    function poll(vault, id) {
      pollAbort = true; const my = pollAbort;
      (async function tick() {
        if (my !== pollAbort) return;
        try {
          const j = await (await fetch(`/api/jobs/${encodeURIComponent(vault)}/${id}`)).json();
          if (j.status === 'pending') { setStep('accepted'); setTimeout(tick, 1500); }
          else if (j.status === 'running') { setStep('running'); setTimeout(tick, 1500); }
          else if (j.status === 'done') { setStep('done'); setStatus('Fertig.', 'ok'); }
          else if (j.status === 'failed') { setStatus(`Fehler: ${j.error || 'unbekannt'}`, 'err'); }
        } catch { setTimeout(tick, 3000); }
      })();
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!ready) return;
      const vault = vaultSel.value;
      const content = document.getElementById('content').value.trim();
      const nodeSet = document.getElementById('node_set').value.trim();
      if (!content) return;

      submit.disabled = true;
      setStep('accepted');
      setStatus('Sende…');

      const { api, getToken } = await import('../lib/api.js');
      try {
        const r = await api('/api/ingest', {
          method: 'POST',
          body: JSON.stringify({ vault, content, node_set: nodeSet || null }),
        });
        setStep('running');
        setStatus(`Job #${r.job_id} angenommen (${r.kind}).`);
        document.getElementById('content').value = '';
        poll(vault, r.job_id);
      } catch (e) {
        setStatus(e.message, 'err');
        steps.classList.add('hidden');
      } finally {
        submit.disabled = false;
      }
    });
  </script>

  <style>
    details { border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 0 14px 12px; background: var(--color-surface); }
  </style>
</Base>