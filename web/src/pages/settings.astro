---
import Base from '../layouts/Base.astro';
---
<Base title="Einstellungen">
  <h1>Einstellungen</h1>
  <form id="settings-form">
    <label for="token">API-Token (KB_API_TOKEN)</label>
    <input id="token" type="password" placeholder="Bearer-Token" autocapitalize="off" autocomplete="off" />

    <label for="vault">Standard-Vault</label>
    <select id="vault"></select>

    <button type="submit">Speichern</button>
  </form>
  <div id="result" class="status hidden"></div>

  <script>
    import { initVaultSelect } from '../lib/api.js';

    const tokenEl = document.getElementById('token');
    const vaultSel = document.getElementById('vault');
    const result = document.getElementById('result');

    tokenEl.value = localStorage.getItem('kb_token') || '';
    initVaultSelect(vaultSel);

    document.getElementById('settings-form').addEventListener('submit', (ev) => {
      ev.preventDefault();
      const token = tokenEl.value.trim();
      if (token) localStorage.setItem('kb_token', token);
      else localStorage.removeItem('kb_token');
      localStorage.setItem('kb_vault', vaultSel.value);
      result.className = 'status ok';
      result.textContent = 'Gespeichert.';
    });
  </script>
</Base>
