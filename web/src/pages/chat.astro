---
import Base from '../layouts/Base.astro';
---
<Base title="Chat">
  <div class="page-intro">
    <p class="label" style="margin:0">Vault befragen</p>
    <h1>Was möchtest du wissen?</h1>
  </div>

  <label for="vault">Vault</label>
  <select id="vault" required></select>
  <div id="vault-hint" class="vault-hint hidden"></div>

  <section id="chat-collections" class="collection-control" aria-labelledby="chat-collections-label">
    <h2 id="chat-collections-label" class="label">Antwort auf Sammlungen begrenzen</h2>
    <div id="collection-selector"></div>
  </section>

  <div id="empty" class="empty-state mt-16">
    <h3>Beispiel-Fragen</h3>
    <p>Eine Frage pro Thread.</p>
    <button class="sample-q" data-q="Welche Quellen wurden zuletzt hinzugefügt?">Welche Quellen wurden zuletzt hinzugefügt?</button>
    <button class="sample-q" data-q="Fasse die wichtigsten Punkte zusammen.">Fasse die wichtigsten Punkte zusammen.</button>
    <button class="sample-q" data-q="Welche offenen Fragen ergeben sich?">Welche offenen Fragen ergeben sich?</button>
  </div>

  <div id="history" class="chat-history"></div>

  <form id="form">
    <label for="question">Frage</label>
    <textarea id="question" placeholder="Was möchtest du wissen?" required></textarea>
    <button type="submit" id="submit" class="btn-primary" disabled>Fragen</button>
  </form>

  <div id="error" class="status err hidden"></div>

  <script>
    import { initVaultSelect } from '../lib/bootstrap.js';
    import { mountCollectionSelector } from '../lib/collections.js';

    const vaultSel = document.getElementById('vault');
    const vaultHint = document.getElementById('vault-hint');
    const empty = document.getElementById('empty');
    const history = document.getElementById('history');
    const form = document.getElementById('form');
    const qEl = document.getElementById('question');
    const submit = document.getElementById('submit');
    const errEl = document.getElementById('error');
    let ready = false;
    const hist = [];
    const collectionSelector = mountCollectionSelector(document.getElementById('collection-selector'));

    const TYPE_ICON = { web: '🔗', youtube: '▶', snippet: '📄', file: '📄', pdf: '📕' };

    function escape(s) { return s.replace(/[&<>"]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'})[c]); }
    function md(s) {
      return escape(s).replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
        .replace(/\*(.+?)\*/g, '<em>$1</em>')
        .replace(/`(.+?)`/g, '<code>$1</code>')
        .replace(/\n/g, '<br>');
    }

    function currentVault() { return (vaultSel.selectedOptions[0]?.parentNode?.label || '').toLowerCase(); }
    function showHint() {
      vaultHint.classList.remove('hidden');
      const w = currentVault();
      vaultHint.className = `vault-hint ${w}`;
      vaultHint.innerHTML = `<span class="wall-dot ${w}"></span> ${w === 'local' ? 'Lokal (Ollama)' : 'Cloud (OpenRouter)'}`;
    }

    function stem(path) { return path ? path.split('/').pop()?.replace(/\.md$/, '') || '' : ''; }

    initVaultSelect(vaultSel).then(s => {
      ready = s.ok; submit.disabled = !s.ok;
      if (s.ok) { showHint(); collectionSelector.setVault(vaultSel.value); }
    });
    vaultSel.addEventListener('change', () => { showHint(); collectionSelector.setVault(vaultSel.value, []); });

    for (const b of document.querySelectorAll('.sample-q'))
      b.addEventListener('click', () => { qEl.value = b.dataset.q; qEl.focus(); });

    function render() {
      empty.classList.toggle('hidden', hist.length > 0);
      history.innerHTML = '';
      for (const m of hist) {
        const div = document.createElement('div');
        div.className = `msg ${m.role}`;
        const role = document.createElement('div'); role.className = 'msg-role';
        role.textContent = m.role === 'user' ? 'Du' : 'KB ' + m.vault;
        const bub = document.createElement('div'); bub.className = 'msg-bubble msg-body';
        bub.innerHTML = m.role === 'user' ? escape(m.text) : md(m.text || 'Keine belegte Antwort möglich.');
        if (m.role === 'user' && m.scopeLabels?.length) {
          const scope = document.createElement('div'); scope.className = 'message-scope';
          scope.textContent = `Sammlungen: ${m.scopeLabels.join(', ')}`; bub.appendChild(scope);
        }

        if (m.role === 'kb' && m.citations?.length) {
          const citations = document.createElement('ol');
          citations.className = 'citation-list';
          citations.setAttribute('aria-label', 'Belege nach Aussage');
          for (const citation of m.citations) {
            const item = document.createElement('li');
            item.textContent = `Aussage ${citation.claim_index + 1}: ${citation.evidence_ids.join(', ')}`;
            citations.appendChild(item);
          }
          bub.appendChild(citations);
        }

        if (m.role === 'kb' && m.gaps?.length) {
          const gaps = document.createElement('div');
          gaps.className = 'gap-list status';
          gaps.role = 'status';
          const heading = document.createElement('strong'); heading.textContent = 'Wissenslücken';
          const list = document.createElement('ul');
          for (const gap of m.gaps) {
            const item = document.createElement('li'); item.textContent = gap.detail;
            list.appendChild(item);
          }
          gaps.append(heading, list);
          bub.appendChild(gaps);
        }

        if (m.role === 'kb' && m.sources?.length) {
          const sec = document.createElement('div'); sec.className = 'sources';
          sec.innerHTML = '<div class="sources-label">Quellen</div>';
          for (const s of m.sources) {
            const title = s.title || stem(s.raw_md_path) || s.type || 'Quelle';
            const chip = document.createElement(s.url?.startsWith('http') ? 'a' : 'span');
            chip.className = 'source-chip';
            if (chip.tagName === 'A') { chip.href = s.url; chip.target = '_blank'; chip.rel = 'noopener'; }
            chip.textContent = `${TYPE_ICON[s.type] || '📄'} ${title}${s.locator ? ' · ' + s.locator : ''}`;
            sec.appendChild(chip);
          }
          bub.appendChild(sec);
        }
        div.append(role, bub);
        history.appendChild(div);
      }
      history.lastElementChild?.scrollIntoView({ block: 'end', behavior: 'smooth' });
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const q = qEl.value.trim();
      if (!q || !ready) return;
      const vault = vaultSel.value;
      const collectionIds = collectionSelector.getSelected();
      const scopeLabels = collectionSelector.getSelectedRecords().map((c) => c.label);
      errEl.classList.add('hidden');
      hist.push({ role: 'user', text: q, vault, scopeLabels: [...scopeLabels] });
      render();
      qEl.value = '';
      submit.disabled = true;

      const { api } = await import('../lib/api.js');
      try {
        const r = await api('/api/query', {
          method: 'POST', body: JSON.stringify({ vault, question: q, collection_ids: collectionIds }),
        });
        hist.push({
          role: 'kb', text: r.answer, sources: r.sources || [], citations: r.citations || [],
          gaps: r.gaps || [], vault: r.vault || vault
        });
        render();
      } catch (e) {
        errEl.textContent = e.message; errEl.classList.remove('hidden');
      } finally {
        submit.disabled = false;
      }
    });
  </script>
</Base>
