.graphify_*
.agents/
skills-lock.json

# Docker-eigene Dateien brauchen nicht ins Image.
Dockerfile
docker-compose.yml
.dockerignore

# Docs/Pläne sind kein Runtime-Code.
docs/
plans/
eval/
ops/
