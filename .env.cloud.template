# Business-Instanz: Cloud-LLM, lokale Embeddings, physisch getrennte Wall.
LLM_PROVIDER=custom
LLM_MODEL=openrouter/deepseek/deepseek-v4-flash
LLM_ENDPOINT=https://openrouter.ai/api/v1
LLM_API_KEY=CHANGE_ME

# fastembed läuft in-process (ONNX, CPU) — kein Ollama, VPS-tauglich.
# Multilingual wegen deutscher Inhalte. Nach erstem Ingest NICHT mehr wechseln!
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
EMBEDDING_DIMENSIONS=768
EMBEDDING_BATCH_SIZE=8
HUGGINGFACE_TOKENIZER=sentence-transformers/paraphrase-multilingual-mpnet-base-v2

# Ohne dieses Flag ignoriert search() den datasets-Parameter (alle Daten!).
# kb ist ein Single-User-System mit physisch getrennter Cloud-Wall. Vault-
# Isolation erfolgt über Datasets plus die lokale Source-Allowlist.
ENABLE_BACKEND_ACCESS_CONTROL=false


# Datenpfade werden NICHT hier gesetzt: kb/cognee_io.py leitet sie aus
# config.Instance.var_dir ab (var/<instanz>/cognee_*) — portabel für die VPS.
