<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key><string>de.michelyweb.kb.worker-cloud</string>
    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/uv</string>
        <string>run</string><string>kb</string>
        <string>worker</string><string>cloud</string>
    </array>
    <key>WorkingDirectory</key><string>/Users/marco/coding/kb</string>
    <key>RunAtLoad</key><true/>
    <key>KeepAlive</key><true/>
    <key>StandardOutPath</key><string>/Users/marco/coding/kb/var/cloud/worker.log</string>
    <key>StandardErrorPath</key><string>/Users/marco/coding/kb/var/cloud/worker.err</string>
